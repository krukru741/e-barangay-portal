// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Household {
  id          String     @id @default(cuid())
  houseNumber String?
  street      String
  village     String?
  sitio       String?
  purok       String?
  barangay    String
  city        String     @default("Talisay City")
  province    String     @default("Cebu")
  postalCode  String?
  country     String     @default("Philippines")
  residents   Resident[]
  createdAt   DateTime   @default(now())
}

model Resident {
  id              String   @id @default(cuid())
  firstName       String
  middleName      String?
  lastName        String
  suffix          String?
  birthDate       DateTime
  gender          Gender
  civilStatus     CivilStatus
  contactNumber   String?
  email           String?
  photo           String?
  isIndigent      Boolean  @default(false)
  isSenior        Boolean  @default(false)
  isPWD           Boolean  @default(false)
  isVoter         Boolean  @default(false)
  isHeadOfFamily  Boolean  @default(false)
  isSoloParent    Boolean  @default(false)
  is4PsBeneficiary Boolean @default(false)
  
  occupation            Occupation?
  educationalAttainment EducationalAttainment?
  incomeBracket         IncomeBracket?

  household       Household @relation(fields: [householdId], references: [id])
  householdId     String
  documents       DocumentRequest[]
  blottersAsCom   Blotter[] @relation("Complainant")
  blottersAsRes   Blotter[] @relation("Respondent")
  officials       Official[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  passwordHash    String
  role            UserRole
  isActive        Boolean   @default(true)
  documents       DocumentRequest[]
  auditLogs       AuditLog[]
  createdAt       DateTime  @default(now())
}

model DocumentRequest {
  id            String          @id @default(cuid())
  type          DocumentType
  purpose       String
  status        RequestStatus   @default(PENDING)
  queueNumber   String?
  requestedAt   DateTime        @default(now())
  releasedAt    DateTime?
  remarks       String?
  resident      Resident        @relation(fields: [residentId], references: [id])
  residentId    String
  issuedBy      User?           @relation(fields: [issuedById], references: [id])
  issuedById    String?
  documentFile  String?
  cedulaNumber  String?
  cedulaIssuedAt DateTime?
  feeAmount     Float?
  orNumber      String?
  businessName  String?
  businessAddress String?
  urgency       DocumentUrgency @default(REGULAR)
}

model Blotter {
  id              String        @id @default(cuid())
  blotterNumber   String        @unique
  incidentType    String
  incidentDate    DateTime
  location        String
  narrative       String
  status          BlotterStatus @default(OPEN)
  complainant     Resident?     @relation("Complainant", fields: [complainantId], references: [id])
  complainantId   String?
  complainantName String?       // Used if Complainant is not a registered resident
  respondent      Resident?     @relation("Respondent", fields: [respondentId], references: [id])
  respondentId    String?
  respondentName  String?       // Used if Respondent is not a registered resident
  witnesses       String?       // Free text for witnesses
  actionTaken     String?       // Narrative of action taken by the barangay
  hearings        Hearing[]
  filedAt         DateTime      @default(now())
  resolvedAt      DateTime?
}

model Hearing {
  id          String    @id @default(cuid())
  blotter     Blotter   @relation(fields: [blotterId], references: [id])
  blotterId   String
  scheduledAt DateTime
  outcome     String?
  attendees   String[]
  createdAt   DateTime  @default(now())
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  type        AnnouncementType @default(GENERAL)
  isPinned    Boolean   @default(false)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
}

model Budget {
  id          String   @id @default(cuid())
  year        Int
  totalAmount Float
  source      String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expenditure {
  id          String   @id @default(cuid())
  date        DateTime
  amount      Float
  category    String
  payee       String
  description String
  receiptUrl  String?
  createdAt   DateTime @default(now())
}

model Official {
  id          String    @id @default(cuid())
  resident    Resident  @relation(fields: [residentId], references: [id])
  residentId  String
  position    Position
  committee   String?
  termStart   DateTime
  termEnd     DateTime
  isActive    Boolean   @default(true)
}

model AuditLog {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  action      String
  entity      String
  entityId    String
  details     Json?
  createdAt   DateTime  @default(now())
}

// Enums
enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CivilStatus {
  SINGLE
  MARRIED
  WIDOWED
  SEPARATED
  COHABITING
}

enum DocumentType {
  CLEARANCE
  RESIDENCY
  INDIGENCY
  BUSINESS
  GOOD_MORAL
  ENDORSEMENT
}

enum RequestStatus {
  PENDING
  PROCESSING
  READY
  RELEASED
  CANCELLED
}

enum DocumentUrgency {
  REGULAR
  PRIORITY
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
  OFFICIAL
  RESIDENT
}

enum BlotterStatus {
  OPEN
  ONGOING
  RESOLVED
  ESCALATED
  CLOSED
}

enum Occupation {
  UNEMPLOYED
  STUDENT
  SELF_EMPLOYED
  PRIVATE_EMPLOYEE
  GOVERNMENT_EMPLOYEE
  OTHERS
}

enum EducationalAttainment {
  ELEMENTARY
  HIGH_SCHOOL
  VOCATIONAL
  COLLEGE_GRADUATE
  POST_GRADUATE
  NONE
}

enum IncomeBracket {
  BELOW_10K
  FROM_10K_TO_20K
  FROM_20K_TO_40K
  ABOVE_40K
}

enum AnnouncementType {
  GENERAL
  EMERGENCY
  EVENT
  ADVISORY
}

enum Position {
  CAPTAIN
  KAGAWAD
  SECRETARY
  TREASURER
  SK_CHAIR
  SK_KAGAWAD
}
